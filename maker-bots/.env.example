# ── Chain ──────────────────────────────────────────────────────────────────────
# RPC endpoint for Base Sepolia (testnet) or Base Mainnet
RPC_URL=https://sepolia.base.org
# 84532 = Base Sepolia  |  8453 = Base Mainnet
CHAIN_ID=84532

# ── Contracts ──────────────────────────────────────────────────────────────────
# Deployed MeridianMarket contract address
MARKET_ADDRESS=0x0793531B3CcE2B833298cFeCAEC63ad5c327302d
# Deployed MockUSDC contract address (testnet only — no access control on mint)
USDC_ADDRESS=0x

# ── External services ──────────────────────────────────────────────────────────
# Pyth Hermes REST API (public endpoint, no key required)
HERMES_URL=https://hermes.pyth.network

# ── Wallets ────────────────────────────────────────────────────────────────────
# Private key for the MAKER bot (Bot 1).
# This wallet needs ETH for gas. USDC is minted automatically on testnet.
MAKER_PK=

# Private key for the BUYER bot (Bot 2).
# This wallet needs ETH for gas. USDC is minted automatically on testnet.
BUYER_PK=

# ── Maker Bot Parameters ───────────────────────────────────────────────────────
# Number of YES/NO token pairs to mint and quote per market per cycle.
# Each pair costs $1 USDC, so MAKER_QUANTITY=10 → $10 per market per cycle.
MAKER_QUANTITY=10

# Cents on each side of the computed fair value.
# With MAKER_HALF_SPREAD=5 and fair value 60¢ → BID=55¢, ASK=65¢ (10¢ spread).
MAKER_HALF_SPREAD=5

# Sigmoid sensitivity: how aggressively the fair value responds to price distance.
# Higher = fair value moves more steeply when price is away from strike.
# Range: 1.0 (flat) to 10.0 (very steep). Default 3.0 is a reasonable starting point.
MAKER_SENSITIVITY=3.0

# Assumed total NYSE session length in hours. Used for the time-weight calculation.
# The closer to expiry, the higher the time weight, making quotes more aggressive.
MAKER_HOURS_TOTAL=8.0

# Skip quoting if the computed fair value is below this threshold (cents).
# Markets with fair value < 5 are near-certain losers for YES — not worth quoting.
MAKER_MIN_FAIR_VALUE=5

# Skip quoting if the computed fair value is above this threshold (cents).
# Markets with fair value > 95 are near-certain winners for YES — not worth quoting.
MAKER_MAX_FAIR_VALUE=95

# Cron expression for the maker bot (America/New_York timezone).
# Default: every 5 minutes. Use a standard 5-field cron expression.
MAKER_CRON=*/5 * * * *

# ── Buyer Bot Parameters ───────────────────────────────────────────────────────
# Maximum number of YES/NO pairs to buy per in-the-money market per cycle.
# Each pair costs $1 USDC, so BUYER_QUANTITY=10 → up to $10 per market.
BUYER_QUANTITY=10

# Minimum raw USDC (6-decimal units) to accept from selling YES at market.
# 0 = accept any price. Raise this to avoid unfavourable fills in thin books.
# Example: 3000000 = minimum $3 proceeds for 10 YES tokens (30¢ avg fill).
BUYER_MIN_YES_PROCEEDS=0

# Maximum number of resting BID orders to cross in a single buyNoMarket call.
BUYER_MAX_FILLS=10

# Only buy if the best BID side has at least this many units of total depth.
# Guards against buying into an almost-empty book.
BUYER_MIN_BID_DEPTH=5

# Always leave at least this many units on the BID side after buying.
# Ensures the maker's quotes are never fully consumed in a single cycle.
BUYER_RESERVE_DEPTH=5

# Cron expression for the buyer bot (America/New_York timezone).
# Default: every 30 minutes. Running less frequently than the maker avoids
# immediately consuming freshly posted maker liquidity.
BUYER_CRON=*/30 * * * *

# ── Logging ────────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
