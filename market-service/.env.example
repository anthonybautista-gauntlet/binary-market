# ── Chain ───────────────────────────────────────────────────────────────────
# RPC endpoint for the target chain
RPC_URL=https://sepolia.base.org
# 84532 = Base Sepolia (testnet), 8453 = Base mainnet
CHAIN_ID=84532

# ── Contracts ───────────────────────────────────────────────────────────────
MARKET_ADDRESS=0x0793531B3CcE2B833298cFeCAEC63ad5c327302d
# Pyth oracle contract address
# Base Sepolia (testnet): 0xA2aa501b19aff244D90cc15a4Cf739D2725B5729
# Base Mainnet:           0x8250f4aF4B972684F7b336503E2D6dFeDeB1487a
PYTH_ADDRESS=0xA2aa501b19aff244D90cc15a4Cf739D2725B5729

# ── Wallets ─────────────────────────────────────────────────────────────────
# Private key of OPERATOR_ROLE holder (market creation)
OPERATOR_PK=
# Private key of SETTLER_ROLE holder (settlement) — can be same as OPERATOR_PK
SETTLER_PK=
# Private key of DEFAULT_ADMIN_ROLE holder (admin settlement override fallback)
# This is the deployer wallet. Required for the adminSettle job (Yahoo Finance fallback).
ADMIN_PK=

# ── Mode ────────────────────────────────────────────────────────────────────
# Set to "true" on testnet to enable the hourly pricePusher job.
# Both testnet and mainnet use real Pyth VAA bytes for price updates.
# Set to "false" (or leave unset) on mainnet to disable pricePusher.
IS_TESTNET=true

# ── Pyth Hermes ─────────────────────────────────────────────────────────────
HERMES_URL=https://hermes.pyth.network

# ── Scheduling (cron expressions, America/New_York timezone) ────────────────
# Default: create markets at 08:00 ET Mon–Fri
CREATE_MARKETS_CRON=0 8 * * 1-5
# Default: settle markets at 16:05 ET Mon–Fri (early-close days handled at runtime)
SETTLE_MARKETS_CRON=5 16 * * 1-5
# Admin override fallback: 16:15 ET = exactly 15 min after close (ADMIN_OVERRIDE_DELAY = 900s)
# Only settles markets that were not settled by the Hermes path at 16:05.
ADMIN_SETTLE_CRON=15 16 * * 1-5
# Price pusher interval in minutes (IS_TESTNET=true only)
PRICE_PUSHER_INTERVAL_MIN=60
# Maximum age in seconds for a Hermes price to be considered fresh enough to push.
# Feeds older than this threshold are skipped with a warning. Default: 600 (10 min).
PRICE_PUSHER_MAX_AGE_SECONDS=600
