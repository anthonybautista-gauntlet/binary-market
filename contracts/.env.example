# ── Deployer ──────────────────────────────────────────────────────────────────
# Private key and matching public address of the wallet that deploys the contract
# and receives DEFAULT_ADMIN_ROLE.
DEPLOYER_PK=0x
DEPLOYER_ADDRESS=0x

# ── RPC endpoints ─────────────────────────────────────────────────────────────
# Official public endpoints — rate-limited, fine for scripts/testnet.
# For production replace with a provider URL (Alchemy, QuickNode, Infura, etc.).
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_RPC=https://mainnet.base.org

# ── Oracle ────────────────────────────────────────────────────────────────────
# Pyth contract address on the target chain.
# Base Sepolia:  0xA2aa501b19aff244D90cc15a4Cf739D2725B5729
# Base Mainnet:  0x8250f4aF4B972684F7b336503E2D6dFeDeB1487a
# Leave empty to auto-deploy MockPyth (local / testnet only; use real address for any
# network where Pyth is deployed — see switching guide in README).
PYTH_ADDRESS=0xA2aa501b19aff244D90cc15a4Cf739D2725B5729

# ── Collateral ────────────────────────────────────────────────────────────────
# USDC contract address on the target chain.
# Base Sepolia (bridged USDC): 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base Mainnet:                0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Leave empty to auto-deploy MockUSDC (testnet only).
USDC_ADDRESS=

# ── Protocol fees ─────────────────────────────────────────────────────────────
# Address that receives fees forwarded on each winning redemption.
# Defaults to DEPLOYER_ADDRESS if omitted.
FEE_RECIPIENT=0x

# Fee in basis points applied to winning redemptions (50 = 0.5%, max 200 = 2%).
# Snapshotted into each market struct at creation time; changing this after
# deployment only affects markets created afterwards.
FEE_BPS=50

# ── Post-deploy operational wallets ───────────────────────────────────────────
# Address to be granted OPERATOR_ROLE (creates markets via CreateMarkets.s.sol).
OPERATOR_ADDRESS=0x

# Address to be granted SETTLER_ROLE (calls settleMarket).
SETTLER_ADDRESS=0x

# ── CreateMarkets.s.sol ───────────────────────────────────────────────────────
# Private key of the OPERATOR_ROLE wallet — used to broadcast CreateMarkets.s.sol.
OPERATOR_PK=0x

# Deployed MeridianMarket address (set after running Deploy.s.sol).
MARKET_ADDRESS=0x

# Optional: override expiry timestamp for all markets created by CreateMarkets.s.sol.
# Defaults to block.timestamp + 7 days if omitted.
# EXPIRY_TIMESTAMP=

# Previous closing prices in whole dollars for each MAG7 ticker.
# The script computes strike bins at ±9%, ±6%, ±3%, and ATM, rounded to the nearest $10.
# If omitted, falls back to reference prices from the oracle research doc (2026-03-06).
# Update these each morning before running CreateMarkets.s.sol.
# AAPL_PRICE=256
# MSFT_PRICE=410
# NVDA_PRICE=179
# GOOGL_PRICE=298
# AMZN_PRICE=215
# META_PRICE=645
# TSLA_PRICE=398
